BOT_TOKEN=

# polling / webhook
RUN_MODE=webhook
WEBHOOK_BASE_URL=https://uc.khixang.dpdns.org
WEBHOOK_PATH=/telegram/webhook
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8787
WEBHOOK_SECRET_TOKEN=change_me_to_long_random_string

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# 可选：积分互通 Redis（和 dice_bot/clans_bot 同源时填写）
POINTS_REDIS_HOST=
POINTS_REDIS_PORT=6379
POINTS_REDIS_DB=0
POINTS_REDIS_PASSWORD=

# 0 表示不限制
ALLOWED_CHAT_ID=0
ALLOWED_THREAD_ID=0
# 超管用户ID列表（逗号分隔），可执行 /uc_force_stop
SUPER_ADMIN_IDS=

MIN_PLAYERS=4
MAX_PLAYERS=12

# 积分与节奏
BET_PER_PLAYER=100
SHARED_POINTS_INIT=20000
SPEAK_TIMEOUT_SECONDS=90
SPEAK_REMIND_BEFORE_SECONDS=30
WATCHDOG_INTERVAL_SECONDS=3

# 必填，格式：词1|词2;词3|词4
WORD_PAIRS=牛奶|豆浆;猫|老虎;牙刷|梳子
